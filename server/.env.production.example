# Y and Z — production config (managed MongoDB + AWS S3/CloudFront).
# Copy to .env.production and provide real secrets via your secrets manager.
NODE_ENV=production
PORT=4000

MONGO_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net
MONGO_DB=yandz

# Real AWS S3: leave S3_ENDPOINT unset to use AWS defaults; path style off.
S3_REGION=us-east-1
S3_BUCKET=yandz-assets-prod
S3_FORCE_PATH_STYLE=false
S3_ACCESS_KEY_ID=__from_secrets__
S3_SECRET_ACCESS_KEY=__from_secrets__
# Public asset delivery via CloudFront.
S3_PUBLIC_BASE_URL=https://cdn.yandz.app

JWT_SECRET=__from_secrets__
GOOGLE_CLIENT_ID=__from_secrets__
VAPID_PUBLIC_KEY=__from_secrets__
VAPID_PRIVATE_KEY=__from_secrets__
VAPID_SUBJECT=mailto:admin@yandz.app
CORS_ORIGINS=https://yandz.app
