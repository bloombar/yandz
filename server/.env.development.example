# Y and Z — development config (local MongoDB + local MinIO).
# Copy to .env.development and adjust. Loaded when NODE_ENV != production.
NODE_ENV=development
PORT=4000

# Local MongoDB (shared instance) — isolated database for this app.
MONGO_URI=mongodb://admin:secret@localhost:27017
MONGO_DB=yandz_dev

# Local MinIO (S3-compatible). forcePathStyle is required for MinIO.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=yandz-assets
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# Reads in dev go straight to MinIO; in prod set this to the CloudFront URL.
S3_PUBLIC_BASE_URL=http://localhost:9000/yandz-assets

JWT_SECRET=dev-insecure-secret
GOOGLE_CLIENT_ID=
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yandz.app
CORS_ORIGINS=*
