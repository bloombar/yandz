# Y and Z extension — build-time config (Vite/WXT inlines VITE_* vars).
# Copy to `.env` (or `.env.development`) and adjust, then rebuild the extension.

# Origin of the API server (host + PORT). Must match the server's PORT.
# Defaults to http://localhost:4100 when unset.
VITE_API_BASE=http://localhost:4100
